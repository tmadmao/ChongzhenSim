# 崇祯皇帝模拟器 - 环境变量配置

# ===========================================
# 前端配置 (Vite)
# ===========================================

# OpenAI API Key（可选，如果配置了后端代理则不需要）
# VITE_OPENAI_API_KEY=sk-xxxxx

# DeepSeek API Key（可选，作为 OpenAI 的替代）
# VITE_DEEPSEEK_API_KEY=sk-xxxxx

# 自定义 API Base URL（可选）
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（可选，默认 gpt-4o）
# VITE_MODEL_NAME=gpt-4o-mini

# 后端 API 地址（如果使用后端代理）
VITE_API_BASE=http://localhost:3001

# ===========================================
# 后端配置 (Express Server)
# ===========================================

# 服务端口
PORT=3001

# OpenAI API Key（服务端使用，不会暴露到前端）
OPENAI_API_KEY=sk-your-openai-api-key-here

# 或者使用 DeepSeek API
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
